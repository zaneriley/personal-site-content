#!/usr/bin/env bash

set -o errexit
set -o pipefail

LEFTHOOK_NPX_PACKAGE="${LEFTHOOK_NPX_PACKAGE:-lefthook@2.1.6}"
DRAFT_SAFETY_FIXTURE_DIR=""
CONTENT_VERDICT_ARTIFACT_DIR="${CONTENT_VERDICT_ARTIFACT_DIR:-.tmp/ci-artifacts/content-publication}"

load_environment() {
    if [ -f .env ]; then
        set -o allexport
        # shellcheck disable=SC1091
        . .env
        set +o allexport
    fi
}

markdown_files() {
    find . \
        -mindepth 2 \
        -type f \
        -name "*.md" \
        ! -path "./.git/*" \
        -print0 \
        | LC_ALL=C sort -z
}

is_plaintext_draft() {
    local file=$1

    grep -Eiq '^[[:space:]]*is_draft:[[:space:]]*['\''"]?true['\''"]?[[:space:]]*(#.*)?$' "$file"
}

require_encryption_key() {
    load_environment

    if [ -z "${ENCRYPTION_KEY:-}" ]; then
        echo "Error: ENCRYPTION_KEY is not set. Add it to .env before encrypting or decrypting drafts."
        exit 1
    fi
}

encrypt_file() {
    local file=$1
    if openssl aes-256-cbc -salt -pbkdf2 -in "$file" -out "$file.enc" -k "$ENCRYPTION_KEY"; then  # SC2181 fixed
        rm "$file"
        echo "Encrypted: $file"
    else
        echo "Error encrypting: $file"
        return 1
    fi
}

decrypt_file() {
    local file=$1
    if openssl aes-256-cbc -d -pbkdf2 -in "$file" -out "${file%.enc}" -k "$ENCRYPTION_KEY"; then  # SC2181 fixed
        rm "$file"
        echo "Decrypted: $file"
    else
        echo "Error decrypting: $file"
        return 1
    fi
}

encrypt_drafts() {
    local file

    while IFS= read -r -d "" file; do
        if is_plaintext_draft "$file"; then
            encrypt_file "$file"
        fi
    done < <(markdown_files)
}

decrypt_drafts() {
    find . -mindepth 2 -type f -name "*.md.enc" | while read -r file; do
        decrypt_file "$file"
    done
}

check_unencrypted_drafts() {
    local file
    local found=0
    local relative_path

    while IFS= read -r -d "" file; do
        if is_plaintext_draft "$file"; then
            relative_path="${file#./}"
            echo "Unencrypted draft found: ${relative_path}"
            found=1
        fi
    done < <(markdown_files)

    if [ "$found" -eq 1 ]; then
        return 1
    fi
}

repo_ref() {
    local repo_path=$1
    local ref

    ref="$(git -C "$repo_path" rev-parse --short=12 HEAD 2>/dev/null || printf "unknown")"

    if [ "$ref" != "unknown" ] && [ -n "$(git -C "$repo_path" status --porcelain)" ]; then
        printf "%s-dirty" "$ref"
    else
        printf "%s" "$ref"
    fi
}

ci_validate() {
    local app_path=${1:-}
    local content_path
    local app_ref
    local content_ref
    local draft_output
    local validation_output
    local validation_status
    local publishable_count
    local reason

    if [ -z "$app_path" ]; then
        echo "Usage: $0 ci:validate /path/to/personal-site"
        exit 1
    fi

    if [ ! -d "$app_path" ]; then
        echo "Portfolio app path does not exist or is not a directory: $app_path"
        exit 1
    fi

    app_path="$(cd "$app_path" && pwd -P)"
    content_path="$(pwd -P)"

    if [ ! -x "$app_path/run" ]; then
        echo "Portfolio app run command is not executable: $app_path/run"
        exit 1
    fi

    content_ref="$(repo_ref "$content_path")"
    app_ref="$(repo_ref "$app_path")"

    echo "Validating content commit $content_ref against personal-site commit $app_ref"

    if ! draft_output="$(check_unencrypted_drafts 2>&1)"; then
        printf "%s\n" "$draft_output"
        reason="$(first_nonempty_line "$draft_output")"
        write_content_verdict "rejected" "rejected: ${reason}" "$reason"
        return 1
    fi

    set +o errexit
    validation_output="$(
        {
            cd "$app_path"
            ./run ci:setup-env
            ./run ci:content-validate "$content_path"
        } 2>&1
    )"
    validation_status=$?
    set -o errexit

    printf "%s\n" "$validation_output"

    if [ "$validation_status" -ne 0 ]; then
        reason="$(first_validation_error "$validation_output")"

        if [ -n "$reason" ]; then
            write_content_verdict "rejected" "rejected: ${reason}" "$reason"
        else
            write_content_verdict "failed" "failed: validation command did not complete" \
                "Content validation exited ${validation_status} before returning an author-facing reason."
        fi

        return "$validation_status"
    fi

    publishable_count="$(changed_publishable_path_count)"

    if [ "$publishable_count" -eq 0 ]; then
        write_content_verdict "ignored" "ignored: no publishable content changed" \
            "No changed Markdown files under notes/*/*.md or case-studies/*/*.md."
    else
        write_content_verdict "accepted" \
            "would publish (${publishable_count} publishable file(s)); no live origin yet" \
            "Validation passed. There is no live origin yet, so this does not claim the site updated."
    fi
}

app_content_validate() {
    local app_path=$1
    local content_path

    content_path="$(pwd -P)"

    (
        cd "$app_path"
        ./run ci:setup-env
        ./run ci:content-validate "$content_path"
    )
}

run_lefthook() {
    if command -v lefthook >/dev/null 2>&1; then
        lefthook "$@"
        return
    fi

    if command -v npx >/dev/null 2>&1; then
        npx --yes "$LEFTHOOK_NPX_PACKAGE" "$@"
        return
    fi

    echo "lefthook is not installed and npx is unavailable"
    return 1
}

lint_shell() {
    if command -v shellcheck >/dev/null 2>&1; then
        shellcheck run
        return
    fi

    if command -v docker >/dev/null 2>&1; then
        docker container run --rm \
            -v "${PWD}:/mnt" \
            -w /mnt \
            koalaman/shellcheck:stable run
        return
    fi

    echo "shellcheck is not installed and docker is unavailable"
    return 1
}

write_draft_safety_fixture() {
    DRAFT_SAFETY_FIXTURE_DIR="notes/draft-safety-fixture"

    unstage_draft_safety_fixture
    rm -rf "$DRAFT_SAFETY_FIXTURE_DIR"
    mkdir -p "$DRAFT_SAFETY_FIXTURE_DIR"

    write_plaintext_draft_fixture "plaintext-draft.md" "true"
    write_plaintext_draft_fixture "plaintext-draft-titlecase.md" "True"
    write_plaintext_draft_fixture "plaintext-draft-uppercase.md" "TRUE"
    write_plaintext_draft_fixture "plaintext-draft-double-quoted.md" '"true"'
    write_plaintext_draft_fixture "plaintext-draft-single-quoted.md" "'true'"
}

cleanup_draft_safety_fixture() {
    if [ -n "$DRAFT_SAFETY_FIXTURE_DIR" ]; then
        unstage_draft_safety_fixture
        rm -rf "$DRAFT_SAFETY_FIXTURE_DIR"
    fi
}

unstage_draft_safety_fixture() {
    if [ -n "$DRAFT_SAFETY_FIXTURE_DIR" ] && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        git rm --cached --quiet --ignore-unmatch "$DRAFT_SAFETY_FIXTURE_DIR"/*.md 2>/dev/null || true
    fi
}

expect_failure_containing() {
    local label=$1
    local expected=$2
    local output

    shift 2

    if output="$("$@" 2>&1)"; then
        echo "${label} unexpectedly passed"
        if [ -n "$output" ]; then
            printf "%s\n" "$output"
        fi
        return 1
    fi

    case "$output" in
        *"$expected"*)
            echo "${label} blocked plaintext draft: ${expected}"
            ;;
        *)
            echo "${label} failed, but did not print expected message: ${expected}"
            if [ -n "$output" ]; then
                printf "%s\n" "$output"
            fi
            return 1
            ;;
    esac
}

ci_draft_safety() {
    local app_path=${1:-}
    local fixture_path="notes/draft-safety-fixture/plaintext-draft.md"
    local titlecase_fixture_path="notes/draft-safety-fixture/plaintext-draft-titlecase.md"
    local uppercase_fixture_path="notes/draft-safety-fixture/plaintext-draft-uppercase.md"
    local double_quoted_fixture_path="notes/draft-safety-fixture/plaintext-draft-double-quoted.md"
    local single_quoted_fixture_path="notes/draft-safety-fixture/plaintext-draft-single-quoted.md"
    local expected_message="Unencrypted draft found: ${fixture_path}"
    local app_validator_message="${fixture_path}: unencrypted draft"

    if [ -z "$app_path" ]; then
        echo "Usage: $0 ci:draft-safety /path/to/personal-site"
        exit 1
    fi

    if [ ! -d "$app_path" ]; then
        echo "Portfolio app path does not exist or is not a directory: $app_path"
        exit 1
    fi

    trap cleanup_draft_safety_fixture EXIT
    write_draft_safety_fixture

    expect_failure_containing \
        "./run check_unencrypted" \
        "$expected_message" \
        ./run check_unencrypted

    expect_failure_containing \
        "./run check_unencrypted titlecase YAML bool" \
        "Unencrypted draft found: ${titlecase_fixture_path}" \
        ./run check_unencrypted

    expect_failure_containing \
        "./run check_unencrypted uppercase YAML bool" \
        "Unencrypted draft found: ${uppercase_fixture_path}" \
        ./run check_unencrypted

    expect_failure_containing \
        "./run check_unencrypted double-quoted true" \
        "Unencrypted draft found: ${double_quoted_fixture_path}" \
        ./run check_unencrypted

    expect_failure_containing \
        "./run check_unencrypted single-quoted true" \
        "Unencrypted draft found: ${single_quoted_fixture_path}" \
        ./run check_unencrypted

    git add -f "$fixture_path"

    expect_failure_containing \
        "lefthook run pre-commit" \
        "$expected_message" \
        run_lefthook run pre-commit

    expect_failure_containing \
        "lefthook run pre-push" \
        "$expected_message" \
        run_lefthook run pre-push

    write_draft_safety_fixture

    expect_failure_containing \
        "./run ci:validate" \
        "$expected_message" \
        ./run ci:validate "$app_path"

    expect_failure_containing \
        "./run ci:content-validate direct app validator" \
        "$app_validator_message" \
        app_content_validate "$app_path"
}

changed_publishable_path_count() {
    local range=${CONTENT_VALIDATE_DIFF_RANGE:-}

    if [ -z "$range" ]; then
        echo 1
        return
    fi

    git diff --name-only --diff-filter=ACDMRT "$range" -- \
        | publishable_paths \
        | wc -l \
        | tr -d " "
}

publishable_paths() {
    local path

    while IFS= read -r path; do
        case "$path" in
            notes/*/*.md | case-studies/*/*.md)
                printf "%s\n" "$path"
                ;;
        esac
    done
}

first_nonempty_line() {
    printf "%s\n" "$1" | awk 'NF {print; exit}'
}

first_validation_error() {
    printf "%s\n" "$1" | awk '/^- / {sub(/^- /, ""); print; exit}'
}

write_content_verdict() {
    local verdict=$1
    local description=$2
    local reason=$3
    local status_description
    local summary_file

    mkdir -p "$CONTENT_VERDICT_ARTIFACT_DIR"

    status_description="$(short_status_description "$description")"

    printf "%s\n" "$verdict" > "$CONTENT_VERDICT_ARTIFACT_DIR/verdict.txt"
    printf "%s\n" "$status_description" > "$CONTENT_VERDICT_ARTIFACT_DIR/description.txt"
    printf "%s\n" "$reason" > "$CONTENT_VERDICT_ARTIFACT_DIR/reason.txt"

    summary_file="$CONTENT_VERDICT_ARTIFACT_DIR/summary.md"

    {
        printf "%s\n" "## Content validation verdict"
        printf "%s\n" ""
        printf "%s\n" "- Verdict: \`${verdict}\`"
        printf "%s\n" "- Summary: ${description}"
        printf "%s\n" "- Status description: ${status_description}"
        printf "%s\n" "- Reason: ${reason}"
    } > "$summary_file"

    if [ -n "${GITHUB_STEP_SUMMARY:-}" ]; then
        cat "$summary_file" >> "$GITHUB_STEP_SUMMARY"
    fi
}

short_status_description() {
    local description=$1

    if [ "${#description}" -le 140 ]; then
        printf "%s\n" "$description"
        return
    fi

    printf "%.137s...\n" "$description"
}

write_plaintext_draft_fixture() {
    local file_name=$1
    local draft_value=$2

    {
        printf "%s\n" "---"
        printf "%s\n" "title: Plaintext Draft Fixture"
        printf "%s\n" "is_draft: ${draft_value}"
        printf "%s\n" "---"
        printf "%s\n" ""
        printf "%s\n" "This fixture must never pass draft-safety checks."
    } > "${DRAFT_SAFETY_FIXTURE_DIR}/${file_name}"
}

if [ "$#" -gt 0 ]; then
    command=$1
    shift
else
    command=""
fi

case "$command" in
    encrypt)
        require_encryption_key
        encrypt_drafts
        ;;
    decrypt)
        require_encryption_key
        decrypt_drafts
        ;;
    check_unencrypted)
        check_unencrypted_drafts
        ;;
    lint:shell)
        lint_shell
        ;;
    ci:lint)
        lint_shell
        ;;
    ci:draft-safety)
        ci_draft_safety "$@"
        ;;
    ci:validate)
        ci_validate "$@"
        ;;
    *)
        echo "Usage: $0 {encrypt|decrypt|check_unencrypted|lint:shell|ci:lint|ci:draft-safety|ci:validate}"
        exit 1
        ;;
esac
