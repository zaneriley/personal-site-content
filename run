#!/usr/bin/env bash

set -o errexit
set -o pipefail

load_environment() {
    if [ -f .env ]; then
        set -o allexport
        # shellcheck disable=SC1091
        . .env
        set +o allexport
    fi
}

require_encryption_key() {
    load_environment

    if [ -z "${ENCRYPTION_KEY:-}" ]; then
        echo "Error: ENCRYPTION_KEY is not set. Add it to .env before encrypting or decrypting drafts."
        exit 1
    fi
}

encrypt_file() {
    local file=$1
    if openssl aes-256-cbc -salt -pbkdf2 -in "$file" -out "$file.enc" -k "$ENCRYPTION_KEY"; then  # SC2181 fixed
        rm "$file"
        echo "Encrypted: $file"
    else
        echo "Error encrypting: $file"
    fi
}

decrypt_file() {
    local file=$1
    if openssl aes-256-cbc -d -pbkdf2 -in "$file" -out "${file%.enc}" -k "$ENCRYPTION_KEY"; then  # SC2181 fixed
        rm "$file"
        echo "Decrypted: $file"
    else
        echo "Error decrypting: $file"
    fi
}

encrypt_drafts() {
    find . -mindepth 2 -type f -name "*.md" | while read -r file; do
        if grep -q 'is_draft: true' "$file"; then
            encrypt_file "$file"
        fi
    done
}

decrypt_drafts() {
    find . -mindepth 2 -type f -name "*.md.enc" | while read -r file; do
        decrypt_file "$file"
    done
}

check_unencrypted_drafts() {
    find . -mindepth 2 -type f -name "*.md" | while read -r file; do
        if grep -q 'is_draft: true' "$file"; then
            echo "Unencrypted draft found: $file"
            exit 1
        fi
    done
}

repo_ref() {
    local repo_path=$1

    git -C "$repo_path" rev-parse --short=12 HEAD 2>/dev/null || printf "unknown"
}

ci_validate() {
    local app_path=${1:-}
    local content_path
    local app_ref
    local content_ref

    if [ -z "$app_path" ]; then
        echo "Usage: $0 ci:validate /path/to/personal-site"
        exit 1
    fi

    if [ ! -d "$app_path" ]; then
        echo "Portfolio app path does not exist or is not a directory: $app_path"
        exit 1
    fi

    app_path="$(cd "$app_path" && pwd -P)"
    content_path="$(pwd -P)"

    if [ ! -x "$app_path/run" ]; then
        echo "Portfolio app run command is not executable: $app_path/run"
        exit 1
    fi

    content_ref="$(repo_ref "$content_path")"
    app_ref="$(repo_ref "$app_path")"

    echo "Validating content commit $content_ref against personal-site commit $app_ref"

    check_unencrypted_drafts

    (
        cd "$app_path"
        ./run ci:setup-env
        ./run ci:content-validate "$content_path"
    )
}

if [ "$#" -gt 0 ]; then
    command=$1
    shift
else
    command=""
fi

case "$command" in
    encrypt)
        require_encryption_key
        encrypt_drafts
        ;;
    decrypt)
        require_encryption_key
        decrypt_drafts
        ;;
    check_unencrypted)
        check_unencrypted_drafts
        ;;
    ci:validate)
        ci_validate "$@"
        ;;
    *)
        echo "Usage: $0 {encrypt|decrypt|check_unencrypted|ci:validate}"
        exit 1
        ;;
esac
